# test-management/traceability/requirements_traceability_matrix.csv
# Requirements Traceability Matrix — POS Test Platform
# 
# This file can be imported into Excel/Google Sheets as a CSV.
# Fields:
#   - REQ_ID: Requirement identifier
#   - REQ_TITLE: Requirement title
#   - REQ_DESCRIPTION: Requirement description
#   - TEST_CASE_ID: Associated test case ID(s) (comma-separated)
#   - TEST_TYPE: Manual/Automated
#   - AUTOMATION_STATUS: Automated/Manual/Planned
#   - TEST_FILE: Location of test implementation (if automated)
#   - SOURCE: Requirement source (Job Description, Industry Standard, etc.)
#   - PRIORITY: High/Medium/Low
#   - LAST_UPDATED: Date of last update

REQ_ID,REQ_TITLE,REQ_DESCRIPTION,TEST_CASE_ID,TEST_TYPE,AUTOMATION_STATUS,TEST_FILE,SOURCE,PRIORITY,LAST_UPDATED
