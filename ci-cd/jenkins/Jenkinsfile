// ci-cd/Jenkinsfile
// POS Test Platform - CI/CD Pipeline
// 
// Two pipeline modes:
//   1. PR Stage (fast): Runs only @smoke-tagged scenarios across all products
//   2. Nightly Full-Regression Stage: Everything, parameterized by product + environment
// 
// Triggered by:
//   - PR: Automatically on pull request
//   - Nightly: Scheduled (e.g., daily at 2 AM)
//   - Manual: With parameters

// ============================================================
// Declarative Pipeline
// ============================================================

pipeline {
    agent any

    parameters {
        choice(
            name: 'PIPELINE_MODE',
            choices: ['pr', 'nightly', 'full'],
            description: 'Pipeline mode: pr (fast smoke), nightly (full regression), full (all with params)'
        )
        choice(
            name: 'DEPLOY_MODE',
            choices: ['docker-compose', 'kubernetes'],
            description: 'Deployment mode for services'
        )
        choice(
            name: 'TEST_PROFILE',
            choices: ['smoke', 'api', 'full', 'product-e2e', 'ui'],
            description: 'Test profile to run'
        )
        choice(
            name: 'PRODUCT_PROFILE',
            choices: ['all', 'elera', 'vision-kiosk', 'smart-hybrid', 'smart-wall', 'smart-wing', 'scs7', 'tcx-display', 'tcx-printer-single', 'tcx-printer-dual'],
            description: 'Product profile for E2E tests'
        )
        string(
            name: 'BASE_URL',
            defaultValue: 'http://localhost',
            description: 'Base URL for POS services'
        )
        booleanParam(
            name: 'SKIP_DEPLOY',
            defaultValue: false,
            description: 'Skip deployment (services already running)'
        )
        booleanParam(
            name: 'RUN_PERFORMANCE',
            defaultValue: false,
            description: 'Run performance tests (nightly only)'
        )
        booleanParam(
            name: 'RUN_UI',
            defaultValue: false,
            description: 'Run UI tests (nightly only)'
        )
        booleanParam(
            name: 'RUN_DIAGNOSTIC',
            defaultValue: false,
            description: 'Run diagnostic tests (nightly only)'
        )
    }

    // ============================================================
    // Environment
    // ============================================================
    environment {
        DOCKER_REGISTRY = credentials('docker-registry') ?: ''
        KUBECONFIG = credentials('kubeconfig') ?: ''
        RESULTS_DIR = 'test-results'
        BUILD_TIMESTAMP = sh(script: "date +'%Y-%m-%d_%H-%M-%S'", returnStdout: true).trim()
        PRICING_URL = "${params.BASE_URL}:8081"
        PROMOTIONS_URL = "${params.BASE_URL}:8082"
        TAX_URL = "${params.BASE_URL}:8083"
        PAYMENT_URL = "${params.BASE_URL}:8084"
        KIOSK_UI_URL = "${params.BASE_URL}:8080"
    }

    // ============================================================
    // Stages
    // ============================================================
    stages {
        stage('Setup') {
            steps {
                script {
                    def mode = params.PIPELINE_MODE
                    echo "========================================"
                    echo "  POS Test Platform Pipeline"
                    echo "========================================"
                    echo "  Mode: ${mode}"
                    echo "  Test Profile: ${params.TEST_PROFILE}"
                    echo "  Product: ${params.PRODUCT_PROFILE}"
                    echo "  BASE_URL: ${params.BASE_URL}"
                    echo "========================================"
                    
                    // Create results directory
                    sh """
                        mkdir -p ${RESULTS_DIR}/{api,e2e,ui,perf,diagnostic,reports}
                    """
                }
            }
        }

        stage('Build') {
            steps {
                echo '🛠️ Building components...'
                dir('framework-core') {
                    sh 'mvn clean compile -q'
                }
                dir('product-tests') {
                    sh 'mvn compile -q'
                }
                dir('test-automation') {
                    sh 'mvn clean compile -q'
                }
                echo '✅ Build complete'
            }
        }

        // ============================================================
        // PR Stage: Fast smoke tests only
        // ============================================================
        stage('PR Stage (Smoke Tests)') {
            when {
                expression { params.PIPELINE_MODE == 'pr' }
            }
            steps {
                echo '🚀 Running PR smoke tests...'
                
                script {
                    // Start services if not skipped
                    if (!params.SKIP_DEPLOY) {
                        sh 'docker-compose up -d'
                        sh 'sleep 10'
                    }
                    
                    // Run only smoke-tagged tests
                    dir('product-tests') {
                        sh """
                            mvn test \
                                -Dgroups=smoke \
                                -DPRICING_SERVICE_URL=${env.PRICING_URL} \
                                -DPROMOTIONS_SERVICE_URL=${env.PROMOTIONS_URL} \
                                -DTAX_SERVICE_URL=${env.TAX_URL} \
                                -DPAYMENT_GATEWAY_URL=${env.PAYMENT_URL}
                        """
                    }
                    
                    // Also run API smoke tests
                    dir('test-automation') {
                        sh """
                            mvn test \
                                -Dgroups=smoke \
                                -DPRICING_SERVICE_URL=${env.PRICING_URL} \
                                -DPROMOTIONS_SERVICE_URL=${env.PROMOTIONS_URL} \
                                -DTAX_SERVICE_URL=${env.TAX_URL} \
                                -DPAYMENT_GATEWAY_URL=${env.PAYMENT_URL}
                        """
                    }
                    
                    // Copy results
                    sh """
                        cp -r product-tests/target/surefire-reports/*.xml ${RESULTS_DIR}/api/ || true
                        cp -r test-automation/target/surefire-reports/*.xml ${RESULTS_DIR}/api/ || true
                    """
                }
                
                echo '✅ PR smoke tests complete'
            }
            post {
                always {
                    junit testResults: '**/target/surefire-reports/*.xml', allowEmptyResults: true
                }
                always {
                    sh 'docker-compose down || true'
                }
            }
        }

        // ============================================================
        // Nightly Full-Regression Stage
        // ============================================================
        stage('Nightly Full-Regression') {
            when {
                expression { params.PIPELINE_MODE == 'nightly' }
            }
            parallel {
                stage('API Tests') {
                    when {
                        expression { !params.RUN_UI && !params.RUN_PERFORMANCE && !params.RUN_DIAGNOSTIC }
                    }
                    steps {
                        script {
                            echo '🔬 Running API tests...'
                            dir('test-automation') {
                                sh """
                                    mvn test \
                                        -Dgroups=api,regression \
                                        -DPRICING_SERVICE_URL=${env.PRICING_URL} \
                                        -DPROMOTIONS_SERVICE_URL=${env.PROMOTIONS_URL} \
                                        -DTAX_SERVICE_URL=${env.TAX_URL} \
                                        -DPAYMENT_GATEWAY_URL=${env.PAYMENT_URL}
                                """
                            }
                            sh """
                                cp -r test-automation/target/surefire-reports/*.xml ${RESULTS_DIR}/api/ || true
                            """
                        }
                        echo '✅ API tests complete'
                    }
                }

                // ci-cd/Jenkinsfile (add flaky test handling)

// Add a new stage for flaky tests in the Nightly section

stage('Flaky Tests (Quarantine)') {
    when {
        expression { params.PIPELINE_MODE == 'nightly' }
    }
    steps {
        script {
            echo '⚠️ Running flaky tests (quarantined, non-blocking)...'
            
            dir('product-tests') {
                sh """
                    mvn test \
                        -Dgroups=flaky \
                        -DPRICING_SERVICE_URL=${env.PRICING_URL} \
                        -DPROMOTIONS_SERVICE_URL=${env.PROMOTIONS_URL} \
                        -DTAX_SERVICE_URL=${env.TAX_URL} \
                        -DPAYMENT_GATEWAY_URL=${env.PAYMENT_URL} \
                        -Dflaky.report=true \
                        || true  # Do NOT fail the build
                """
            }
            
            // Archive flaky test results separately
            sh """
                mkdir -p ${RESULTS_DIR}/flaky
                cp -r product-tests/target/surefire-reports/*.xml ${RESULTS_DIR}/flaky/ || true
                cp -r product-tests/target/surefire-reports/*.html ${RESULTS_DIR}/flaky/ || true
            """
            
            // Generate flaky test report
            sh """
                cat > ${RESULTS_DIR}/flaky/flaky-report.html << 'EOF'
                <!DOCTYPE html>
                <html>
                <head><title>Flaky Test Report</title>
                <style>
                    body { font-family: Arial; margin: 20px; }
                    .pass { color: green; }
                    .fail { color: red; }
                    .summary { background: #f5f5f5; padding: 15px; border-radius: 5px; }
                </style>
                </head>
                <body>
                    <h1>⚠️ Flaky Test Report (Quarantine)</h1>
                    <div class="summary">
                        <p><strong>Date:</strong> ${BUILD_TIMESTAMP}</p>
                        <p><strong>Status:</strong> These tests are quarantined and do NOT block the build</p>
                        <p><strong>Action:</strong> Review failures and fix flaky tests</p>
                    </div>
                    <p>See attached test results for details.</p>
                </body>
                </html>
                EOF
            """
        }
        echo '⚠️ Flaky tests completed (non-blocking)'
    }
    post {
        always {
            junit testResults: '${RESULTS_DIR}/flaky/*.xml', allowEmptyResults: true
        }
    }
}

                stage('E2E Tests (Product Matrix)') {
                    steps {
                        script {
                            def product = params.PRODUCT_PROFILE
                            echo "🔬 Running E2E tests for product: ${product}"
                            
                            dir('product-tests') {
                                if (product == 'all') {
                                    sh """
                                        mvn test \
                                            -Dgroups=e2e,regression \
                                            -DPRICING_SERVICE_URL=${env.PRICING_URL} \
                                            -DPROMOTIONS_SERVICE_URL=${env.PROMOTIONS_URL} \
                                            -DTAX_SERVICE_URL=${env.TAX_URL} \
                                            -DPAYMENT_GATEWAY_URL=${env.PAYMENT_URL}
                                    """
                                } else {
                                    def testClass = "com.toshiba.pos.tests.${product.capitalize()}Test"
                                    sh """
                                        mvn test \
                                            -Dtest=${testClass} \
                                            -DPRICING_SERVICE_URL=${env.PRICING_URL} \
                                            -DPROMOTIONS_SERVICE_URL=${env.PROMOTIONS_URL} \
                                            -DTAX_SERVICE_URL=${env.TAX_URL} \
                                            -DPAYMENT_GATEWAY_URL=${env.PAYMENT_URL}
                                    """
                                }
                            }
                            sh """
                                cp -r product-tests/target/surefire-reports/*.xml ${RESULTS_DIR}/e2e/ || true
                            """
                        }
                        echo '✅ E2E tests complete'
                    }
                }

                stage('UI Tests') {
                    when {
                        expression { params.RUN_UI }
                    }
                    steps {
                        script {
                            echo '🖥️ Running UI tests...'
                            
                            // Start UI harness
                            sh '''
                                ./scripts/serve_ui_harness.sh &
                                sleep 5
                            '''
                            
                            dir('test-automation') {
                                sh """
                                    mvn test \
                                        -Dtest=com.toshiba.pos.ui.* \
                                        -DKIOSK_UI_URL=${env.KIOSK_UI_URL} \
                                        -DPRICING_SERVICE_URL=${env.PRICING_URL} \
                                        -DPROMOTIONS_SERVICE_URL=${env.PROMOTIONS_URL} \
                                        -DTAX_SERVICE_URL=${env.TAX_URL} \
                                        -DPAYMENT_GATEWAY_URL=${env.PAYMENT_URL}
                                """
                            }
                            sh '''
                                pkill -f "python3 -m http.server" || true
                                cp -r test-automation/target/surefire-reports/*.xml ${RESULTS_DIR}/ui/ || true
                            '''
                        }
                        echo '✅ UI tests complete'
                    }
                }

                stage('Performance Smoke') {
                    when {
                        expression { params.RUN_PERFORMANCE }
                    }
                    steps {
                        script {
                            echo '⚡ Running performance smoke tests...'
                            sh """
                                jmeter -n -t perf-tests/load-test.jmx \
                                    -JBASE_URL=${params.BASE_URL} \
                                    -JTHREADS=5 \
                                    -JDURATION=60 \
                                    -l ${RESULTS_DIR}/perf/perf-results.csv
                            """
                            sh """
                                mkdir -p ${RESULTS_DIR}/perf/report
                                jmeter -g ${RESULTS_DIR}/perf/perf-results.csv -o ${RESULTS_DIR}/perf/report
                            """
                        }
                        echo '✅ Performance tests complete'
                    }
                }
            }
            post {
                always {
                    junit testResults: '**/target/surefire-reports/*.xml', allowEmptyResults: true
                    publishHTML([
                        reportDir: "${RESULTS_DIR}/reports",
                        reportFiles: 'index.html',
                        reportName: 'Nightly Regression Report'
                    ])
                    archiveArtifacts artifacts: "${RESULTS_DIR}/**/*", allowEmptyArchive: true
                }
                failure {
                    // Create JIRA issue for nightly failures
                    script {
                        echo '❌ Nightly regression failed! Creating JIRA issue...'
                        // In a real environment, this would call JIRA API
                    }
                }
            }
        }

        // ============================================================
        // Full Stage (Manual with All Options)
        // ============================================================
        stage('Full Pipeline') {
            when {
                expression { params.PIPELINE_MODE == 'full' }
            }
            steps {
                script {
                    echo '🚀 Running full pipeline...'
                    // This reuses the existing full pipeline logic from the original Jenkinsfile
                    // For brevity, we reference the existing stages
                    // In a real implementation, this would contain the full pipeline
                }
                echo '✅ Full pipeline complete'
            }
        }

        // ============================================================
        // Publish Reports (Common)
        // ============================================================
        stage('Publish Reports') {
            when {
                expression { params.PIPELINE_MODE != 'pr' }
            }
            steps {
                script {
                    def mode = params.PIPELINE_MODE
                    def modeLabel = mode == 'pr' ? 'PR Smoke' : mode == 'nightly' ? 'Nightly Regression' : 'Full'
                    
                    sh """
                        cat > ${RESULTS_DIR}/reports/index.html << 'EOF'
                        <!DOCTYPE html>
                        <html>
                        <head>
                            <title>POS Test Platform - ${modeLabel} Report</title>
                            <style>
                                body { font-family: Arial, sans-serif; margin: 20px; }
                                h1 { color: #333; }
                                h2 { color: #555; border-bottom: 1px solid #ddd; padding-bottom: 10px; }
                                .success { color: green; }
                                .failure { color: red; }
                                .summary { background: #f5f5f5; padding: 15px; border-radius: 5px; }
                            </style>
                        </head>
                        <body>
                            <h1>📊 POS Test Platform - ${modeLabel} Report</h1>
                            <div class="summary">
                                <p><strong>Build:</strong> ${BUILD_NUMBER}</p>
                                <p><strong>Date:</strong> ${BUILD_TIMESTAMP}</p>
                                <p><strong>Mode:</strong> ${modeLabel}</p>
                                <p><strong>Product:</strong> ${params.PRODUCT_PROFILE}</p>
                            </div>
                            <h2>${currentBuild.currentResult == 'SUCCESS' ? '✅ Pipeline Status: SUCCESS' : '❌ Pipeline Status: FAILED'}</h2>
                            <div>
                                <h3>📁 Test Results</h3>
                                <ul>
                                    <li><a href="../api/TEST-TestSuite.html">API Test Results</a></li>
                                    <li><a href="../e2e/TEST-TestSuite.html">E2E Test Results</a></li>
                                    <li><a href="../ui/TEST-TestSuite.html">UI Test Results</a></li>
                                    <li><a href="../perf/report/index.html">Performance Test Report</a></li>
                                </ul>
                            </div>
                        </body>
                        </html>
                        EOF
                    """
                    
                    publishHTML([
                        reportDir: "${RESULTS_DIR}/reports",
                        reportFiles: 'index.html',
                        reportName: "${modeLabel} Test Report"
                    ])
                    
                    archiveArtifacts artifacts: "${RESULTS_DIR}/**/*", allowEmptyArchive: true
                }
                
                echo '✅ Reports published'
            }
        }
        // ci-cd/Jenkinsfile (add to the Publish Reports stage)

// ============================================================
// Historical Trend Reporting
// ============================================================

stage('Historical Trend Reporting') {
    when {
        expression { params.PIPELINE_MODE in ['nightly', 'full'] }
    }
    steps {
        script {
            echo '📊 Generating historical trend report...'
            
            // Create trends directory
            sh """
                mkdir -p ${RESULTS_DIR}/trends
                mkdir -p ${RESULTS_DIR}/trends/history
            """
            
            // Archive test results as JSON for trend analysis
            def timestamp = new Date().format("yyyy-MM-dd")
            def timestampWithTime = new Date().format("yyyy-MM-dd_HH-mm-ss")
            
            sh """
                echo "Generating trend data for ${timestamp}..."
                
                # Create trend data from surefire reports
                find product-tests/target/surefire-reports -name "*.xml" -exec \
                    python3 -c '
import sys, xml.etree.ElementTree as ET, json, datetime
from pathlib import Path

results = {
    "timestamp": "${timestampWithTime}",
    "build_number": "${BUILD_NUMBER}",
    "tests": {},
    "summary": {"total": 0, "passed": 0, "failed": 0, "skipped": 0}
}

for xml_file in sys.argv[1:]:
    try:
        tree = ET.parse(xml_file)
        root = tree.getroot()
        testsuite = root.find(".")
        if testsuite is not None:
            total = int(testsuite.get("tests", 0))
            failed = int(testsuite.get("failures", 0))
            skipped = int(testsuite.get("skipped", 0))
            passed = total - failed - skipped
            results["summary"]["total"] += total
            results["summary"]["passed"] += passed
            results["summary"]["failed"] += failed
            results["summary"]["skipped"] += skipped
    except Exception as e:
        print(f"Error parsing {xml_file}: {e}", file=sys.stderr)

# Write trend data
with open("${RESULTS_DIR}/trends/history/${timestamp}.json", "w") as f:
    json.dump(results, f, indent=2)
' {} \\; || true
            """
            
            // Generate trend report HTML
            sh """
                cat > ${RESULTS_DIR}/trends/trend-report.html << 'EOF'
                <!DOCTYPE html>
                <html>
                <head>
                    <title>Test Trend Report</title>
                    <style>
                        body { font-family: Arial, sans-serif; margin: 20px; }
                        h1 { color: #333; }
                        .chart-container { margin: 20px 0; }
                        table { border-collapse: collapse; width: 100%; }
                        th, td { border: 1px solid #ddd; padding: 8px; text-align: center; }
                        th { background: #f0f0f0; }
                        .pass { color: green; }
                        .fail { color: red; }
                        .summary { background: #f5f5f5; padding: 15px; border-radius: 5px; }
                        .trend-up { color: green; }
                        .trend-down { color: red; }
                        .trend-flat { color: gray; }
                    </style>
                    <script>
                        // Minimal trend chart using SVG
                        function renderTrend(data) {
                            const width = 600;
                            const height = 300;
                            const padding = 40;
                            const max = Math.max(...data.map(d => d.passed + d.failed), 10);
                            
                            let svg = '<svg width="' + width + '" height="' + height + '">';
                            svg += '<rect width="100%" height="100%" fill="#f9f9f9"/>';
                            
                            // Axes
                            svg += '<line x1="' + padding + '" y1="' + padding + '" x2="' + padding + '" y2="' + (height - padding) + '" stroke="#333"/>';
                            svg += '<line x1="' + padding + '" y1="' + (height - padding) + '" x2="' + (width - padding) + '" y2="' + (height - padding) + '" stroke="#333"/>';
                            
                            // Bars
                            const barWidth = (width - padding * 2) / data.length * 0.7;
                            const spacing = (width - padding * 2) / data.length;
                            
                            data.forEach((d, i) => {
                                const x = padding + i * spacing + (spacing - barWidth) / 2;
                                const passHeight = (d.passed / max) * (height - padding * 2);
                                const failHeight = (d.failed / max) * (height - padding * 2);
                                const yBase = height - padding;
                                
                                // Pass bar
                                svg += '<rect x="' + x + '" y="' + (yBase - passHeight) + '" width="' + barWidth + '" height="' + passHeight + '" fill="green" rx="2"/>';
                                // Fail bar (stacked)
                                if (d.failed > 0) {
                                    svg += '<rect x="' + x + '" y="' + (yBase - passHeight - failHeight) + '" width="' + barWidth + '" height="' + failHeight + '" fill="red" rx="2"/>';
                                }
                                // Date label
                                svg += '<text x="' + (x + barWidth/2) + '" y="' + (yBase + 15) + '" text-anchor="middle" font-size="10" fill="#666">' + d.date + '</text>';
                            });
                            
                            svg += '</svg>';
                            return svg;
                        }
                        
                        async function loadTrendData() {
                            const response = await fetch('history/');
                            // This is a placeholder — in a real implementation, we'd parse the directory
                            // For now, we show a message
                            document.getElementById('trend-placeholder').innerHTML = 
                                '<p>📈 Trend data is being collected. Check the "history" directory for JSON files.</p>';
                        }
                        
                        window.onload = function() {
                            loadTrendData();
                        };
                    </script>
                </head>
                <body>
                    <h1>📈 Test Trend Report</h1>
                    <div class="summary">
                        <p><strong>Latest Build:</strong> ${BUILD_NUMBER}</p>
                        <p><strong>Date:</strong> ${BUILD_TIMESTAMP}</p>
                        <p><strong>Trend Data Directory:</strong> history/</p>
                    </div>
                    
                    <div class="chart-container">
                        <h2>Pass/Fail Trend</h2>
                        <div id="trend-placeholder">
                            <p>Loading trend data...</p>
                        </div>
                    </div>
                    
                    <div class="chart-container">
                        <h2>Recent Results</h2>
                        <table>
                            <thead>
                                <tr><th>Build #</th><th>Date</th><th>Total</th><th>Passed</th><th>Failed</th><th>Skipped</th><th>Pass Rate</th></tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td>${BUILD_NUMBER}</td>
                                    <td>${BUILD_TIMESTAMP}</td>
                                    <td>—</td>
                                    <td>—</td>
                                    <td>—</td>
                                    <td>—</td>
                                    <td>—</td>
                                </tr>
                            </tbody>
                        </table>
                        <p><small>Note: Data is collected from each build. Check history directory for full JSON.</small></p>
                    </div>
                    
                    <div class="chart-container">
                        <h2>About This Report</h2>
                        <p>This report provides historical trend data for test results.</p>
                        <ul>
                            <li><strong>Data Source:</strong> Surefire test reports from each build</li>
                            <li><strong>Storage:</strong> JSON files in <code>history/</code> directory</li>
                            <li><strong>Format:</strong> Each file is named <code>YYYY-MM-DD.json</code></li>
                            <li><strong>Fields:</strong> timestamp, build_number, summary (total, passed, failed, skipped)</li>
                        </ul>
                        <p><a href="history/">View History Directory</a></p>
                    </div>
                </body>
                </html>
                EOF
            """
            
            // Archive trend artifacts
            archiveArtifacts artifacts: "${RESULTS_DIR}/trends/**/*", allowEmptyArchive: true
        }
        
        echo '✅ Historical trend reporting complete'
    }
}
    }

    // ============================================================
    // Post-Build
    // ============================================================
    post {
        always {
            script {
                if (!params.SKIP_DEPLOY) {
                    sh 'docker-compose down || true'
                }
            }
            echo '🧹 Cleanup complete'
        }
        
        failure {
            echo '❌ Pipeline failed!'
        }
        
        success {
            echo '🎉 Pipeline completed successfully!'
        }
    }
}